<!DOCTYPE html>
<html lang="en">
<head>
  <title>{{ title or "Spencer Allan" }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Inter:wght@400;500&display=swap">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/normalize/8.0.0/normalize.min.css">
  <link rel="stylesheet" href="/styles/style.css">
  <link rel="stylesheet" href="/styles/freeform-gallery.css">
  {% if pageType == "index" %}
  <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Press+Start+2P">
  <link rel="stylesheet" href="/styles/index.css">
  {% elif pageType == "about" %}
  <link rel="stylesheet" href="/styles/about.css">
  {% else %}
  <link rel="stylesheet" href="/styles/content.css">
  <link rel="stylesheet" href="/js/photoswipe/dist/photoswipe.css">
  {% endif %}
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/favicon/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon/favicon-16x16.png">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description or 'Spencer Allan\'s personal website' }}">
  <meta name="author" content="Spencer Allan">
  <meta name="keywords" content="{{ keywords or 'spencer allan, chicago, design, architecture' }}">
  <meta property="og:title" content="{{ title or 'Spencer Allan' }}">
  <meta property="og:type" content="website">
  <meta property="og:description" content="Spencer Allan is a Chicago based designer and writer.">
  <meta property="og:url" content="https://spencerallan.net{{ page.url }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title or 'Spencer Allan' }}">
  <meta name="twitter:description" content="Spencer Allan is a Chicago based designer and writer.">
  {% if pageType == "index" %}
  <script src="/js/app.js"></script>
  {% else %}
  <script type="module" src="/js/gallery.js"></script>
  {% endif %}
  <script src="/js/freeform-gallery.js" defer></script>
</head>
<body class="preload">

  <!-- Mobile topbar: tiny asterisk left, INDEX centered -->
  <div class="mobile-topbar">
    {% if isHomepage %}
    <a class="mobile-logo-link" onclick="scrollToTop(150)" style="cursor:pointer;">
      <img src="/assets/icons/logo.svg" alt="Spencer Allan">
    </a>
    {% else %}
    <a class="mobile-logo-link" href="/">
      <img src="/assets/icons/logo.svg" alt="Spencer Allan">
    </a>
    {% endif %}
    <button class="mobile-index-btn" onclick="document.body.classList.toggle('menu-open')">INDEX</button>
  </div>

  <!-- Backdrop — click to close the mobile menu -->
  <div class="mobile-overlay" onclick="document.body.classList.toggle('menu-open')"></div>

  <div class="container">
    <div class="sidebar">
      {% include "sidebar.njk" %}
    </div>
    {{ content | safe }}
  </div>

  {% if pageType == "index" %}
  <script src="/js/index.js"></script>
  {% endif %}
  <footer>
    <div class="footer">
      <a id="bottom-message" href="/content/about/">(っᵔ◡ᵔ)っ</a>
    </div>
  </footer>
</body>
</html>
